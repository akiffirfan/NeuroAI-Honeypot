# Module 6 — honeypot-api environment variables
# Copy this file to .env and fill in all values before running docker compose up.
# NEVER commit .env to version control.
#
# Generate passwords: openssl rand -base64 32 | tr -d '/+='

# PostgreSQL password — must match the value in deploy/module-1-data-layer/.env
POSTGRES_PASSWORD=changeme

# Redis password — must match 'requirepass' in /opt/honeypot/config/redis/redis.conf
REDIS_PASSWORD=changeme

# HoneyDash sensor key — must match SENSOR_API_KEY in /opt/honeydash/backend/.env
# If HoneyDash is not yet deployed, leave as 'changeme'; events still go to Postgres.
HONEYDASH_SENSOR_KEY=changeme

# HoneyDash ingest URL — default reaches the HoneyDash stack on the host loopback.
# Override only if HoneyDash is on a different host or port.
HONEYDASH_URL=http://host.docker.internal:8000
