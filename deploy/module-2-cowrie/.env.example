# Module 2 — Cowrie SSH Honeypot — Environment Template
# Copy to .env and set values before bringing up Module 2.
#
#   cp .env.example .env && chmod 600 .env
#
# This file currently has minimal env vars — Cowrie is configured primarily via
# cowrie.cfg rather than environment variables.  The image tag placeholder exists
# so the operator can pin to a SHA digest before going live without editing
# docker-compose.yml directly.

# ──────────────────────────────────────────────────────────
# IMAGE TAG
# Default: latest (mutable — replace with a SHA digest before production)
# To pin:
#   docker pull cowrie/cowrie:latest
#   docker inspect cowrie/cowrie:latest --format '{{index .RepoDigests 0}}'
# Then set: COWRIE_IMAGE_TAG=cowrie/cowrie@sha256:<64-hex-chars>
# And update docker-compose.yml image line to: image: ${COWRIE_IMAGE_TAG}
COWRIE_IMAGE_TAG=latest

# ──────────────────────────────────────────────────────────
# HOSTNAME (passed as env var and used in cowrie.cfg)
# Must match hostname = in cowrie.cfg to avoid banner/shell mismatch.
COWRIE_HOSTNAME=neurocore-gpu01
