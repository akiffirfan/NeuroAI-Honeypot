# .htpasswd.example — HTTP basic auth password file for dash.neuro.ai
#
# This file protects the HoneyDash operator dashboard at dash.neuro.ai.
# It is a defense-in-depth layer behind the IP allowlist in neuro.conf.
#
# GENERATE THE REAL .htpasswd BEFORE DEPLOYING:
#   sudo apt-get install -y apache2-utils   # provides htpasswd command
#   sudo htpasswd -c /opt/honeypot/config/nginx/.htpasswd <your-username>
#   sudo chown 100000:100000 /opt/honeypot/config/nginx/.htpasswd
#   sudo chmod 640 /opt/honeypot/config/nginx/.htpasswd
#
# The .htpasswd file is bind-mounted into the container at:
#   /usr/local/openresty/nginx/conf/conf.d/.htpasswd
# (because the entire /opt/honeypot/config/nginx/ directory is mounted at that path)
#
# To add a second user without overwriting the existing file, omit the -c flag:
#   sudo htpasswd /opt/honeypot/config/nginx/.htpasswd <second-username>
#
# To reload nginx after changing the password file (no restart needed):
#   docker exec nginx openresty -s reload
#
# IMPORTANT: The auth_basic_user_file path in neuro.conf points to:
#   /usr/local/openresty/nginx/conf/conf.d/.htpasswd
# Make sure this file exists at /opt/honeypot/config/nginx/.htpasswd on the host
# before starting nginx with the full TLS config, or nginx will fail to start.
#
# Example entry (DO NOT use in production — this is for format reference only):
# operator:$apr1$rtzJ0RY/$ItefYv/K6UDpOE2WGtRWu1
#
# The hash above is: username=operator, password=changeme
# Generated with: htpasswd -nb operator changeme
# Any password in this example file is for illustration only.
