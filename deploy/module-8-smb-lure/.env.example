# Module 8 — smb-lure environment variables
# Copy to .env: cp .env.example .env && chmod 600 .env
# Fill in POSTGRES_DSN and REDIS_URL from Module 1 credentials.

# PostgreSQL DSN — must match the honeypot user created by Module 1 init SQL
POSTGRES_DSN=postgresql://honeypot:CHANGE_ME@postgres:5432/honeypot

# Redis URL — must match the requirepass in /opt/honeypot/config/redis/redis.conf
REDIS_URL=redis://:CHANGE_ME@redis:6379

# SMB server identity presented to connecting clients
SENSOR_NAME=neuro-smb-01
SMB_SHARE_NAME=neuro-data-share
SMB_SERVER_NAME=NEURO-TRAIN-01
SMB_DOMAIN=NEURO

# Path inside the container where smb_server.py writes JSON events (newline-delimited)
# This volume is bind-mounted into log-shipper as /var/log/smb:ro
SMB_LOG_FILE=/var/log/smb/smb_events.json
