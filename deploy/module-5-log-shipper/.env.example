# =============================================================================
# Module 5 — log-shipper Environment Variables
# Neuro Honeypot Platform
#
# INSTRUCTIONS:
#   1. Copy this file to .env in the same directory:
#        cp .env.example .env
#   2. Fill in all <placeholder> values.
#   3. NEVER commit .env to version control.
#   4. chmod 600 .env
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL password — MUST match the value in Module 1's .env file.
# The DSN is assembled as: postgresql://honeypot:<this>@postgres:5432/honeypot
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=<copy-from-module-1-.env>

# ---------------------------------------------------------------------------
# Redis password — MUST match the requirepass value in
# /opt/honeypot/config/redis/redis.conf
# ---------------------------------------------------------------------------
REDIS_PASSWORD=<copy-from-redis.conf-requirepass>

# ---------------------------------------------------------------------------
# HoneyDash shared secret — MUST match SENSOR_API_KEY in
# /opt/honeydash/backend/.env
# Set to empty string to disable HoneyDash push (Postgres writes still happen):
#   HONEYDASH_SENSOR_KEY=
# ---------------------------------------------------------------------------
HONEYDASH_SENSOR_KEY=<generate-strong-secret>

# ---------------------------------------------------------------------------
# HoneyDash ingest URL — set to the full base URL of the HoneyDash instance.
#
# SECURITY: leaving this set to a non-empty URL causes log-shipper to push
# attacker IP addresses, credentials, and session data to an EXTERNAL HOST on
# every event. Only enable this after confirming the target URL is correct and
# that you have informed relevant parties of the data transfer.
#
# Leave empty to disable HoneyDash push entirely (Postgres writes still happen):
# ---------------------------------------------------------------------------
HONEYDASH_URL=

# ---------------------------------------------------------------------------
# Telegram Bot API alerting — real-time notifications for high-value events
# Create a bot via @BotFather, get chat ID via @userinfobot
# Leave both empty to disable alerting
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Minimum seconds between alerts from the same source IP.
# Prevents alert flood during automated brute-force scans.
# Default is 60 (one alert per IP per minute).
ALERT_COOLDOWN_SECS=60
