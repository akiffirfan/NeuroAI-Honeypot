# Module 4 — mariadb-lure environment variables
# Copy to .env and populate before docker compose up:
#   cp .env.example .env && chmod 600 .env
#
# Generate strong random passwords:
#   openssl rand -base64 32 | tr -d '/+='
#
# KILL CHAIN: After populating MARIADB_PASSWORD here, inject it into the Cowrie
# honeyfs BEFORE starting mariadb-lure for the first time:
#   NEURO_APP_PASS=$(sudo grep '^MARIADB_PASSWORD=' .env | cut -d= -f2)
#   sudo sed -i "s/REPLACEME-neuro-app-password/${NEURO_APP_PASS}/g" \
#     /opt/honeypot/honeypot/cowrie/fs/root/.config/neuro/config.yaml \
#     /opt/honeypot/honeypot/cowrie/fs/root/.bash_history
# Then restart Cowrie so it picks up the patched pickle.

# MariaDB root password — used for administrative access and verify-module-4.sh checks
MARIADB_ROOT_PASSWORD=CHANGEME-root-password-here

# neuro_app service account password — SELECT-only on neuro_prod
# This is the "leaked credential" planted in Cowrie's honeyfs (kill chain above)
MARIADB_PASSWORD=CHANGEME-neuro-app-password-here
